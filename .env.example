# ============================================================
# ClearLedger Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit your .env file to GitHub.
# ============================================================

# ----------------------------
# Smart Contract (Sepolia)
# ----------------------------
# Your deployed contract address on Ethereum Sepolia testnet
VITE_CONTRACT_ADDRESS=0xYourContractAddressHere

# ----------------------------
# Infura / RPC Provider
# ----------------------------
# Get a free Infura Project ID at https://infura.io
VITE_INFURA_PROJECT_ID=your_infura_project_id_here

# ----------------------------
# Optional: Etherscan API (for block explorer links)
# ----------------------------
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ----------------------------
# Groq AI API (for AI-powered transaction analysis)
# Get a free key at https://console.groq.com
# ----------------------------
VITE_GROQ_API_KEY=your_groq_api_key_here
